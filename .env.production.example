# Copie este arquivo para .env e preencha TODOS os valores antes de subir em produção.
# NUNCA commite o .env real.

# ── Banco de dados ──────────────────────────────────────────────────────────
POSTGRES_PASSWORD=troque-por-senha-forte-aqui

# ── Segurança ───────────────────────────────────────────────────────────────
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# ── Usuário administrador inicial ───────────────────────────────────────────
AUTH_USERNAME=seu.nome
AUTH_PASSWORD=senha-forte-aqui

# ── Ambiente ────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── CORS — domínio(s) do frontend em produção ───────────────────────────────
# Exemplo: CORS_ORIGINS=["https://anac-data.exemplo.gov.br"]
CORS_ORIGINS=["https://SEU-DOMINIO-AQUI"]

# ── URL pública da API (usada pelo frontend Next.js) ────────────────────────
NEXT_PUBLIC_API_URL=https://api.SEU-DOMINIO-AQUI

# ── IA (pelo menos um é necessário para o chat funcionar) ───────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=

# ── Google OAuth (opcional) ──────────────────────────────────────────────────
GOOGLE_CLIENT_ID=

# ── E-mail (opcional — deixe vazio para desabilitar notificações) ────────────
SMTP_HOST=
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# ── Pool do banco (ajuste conforme carga esperada) ───────────────────────────
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Sessão ───────────────────────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=480
